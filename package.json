{
  "scripts": {
    "clear:results": "rimraf allure-results",
    "cy:run": "cypress run --browser chrome --headless --env allure=true",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "test": "npm run clear:results && npm run cy:run && npm run report:generate && npm run allure:open",
    "report:view": "npm run report:generate && npm run allure:open"
  },
  "devDependencies": {
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "@testing-library/cypress": "^10.1.0",
    "allure-commandline": "^2.38.1",
    "cypress": "^15.13.1",
    "cypress-terminal-report": "^7.3.3",
    "cypress-xpath": "^2.0.1",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "rimraf": "^6.1.3"
  },
  "dependencies": {
    "cypress-mochawesome-reporter": "^4.0.2",
    "save-dev": "^0.0.1-security",
    "xlsx": "^0.18.5"
  }
}
