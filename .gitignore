# ==============================
# Dependencies
# ==============================
node_modules/

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==============================
# Cypress Artifacts
# ==============================
cypress/videos/
cypress/screenshots/
cypress/downloads/

# Cypress cache
.cypress-cache/

# ==============================
# Allure Reports
# ==============================
allure-results/
allure-report/

# ==============================
# Coverage Reports (if using nyc)
# ==============================
coverage/
.nyc_output/

# ==============================
# Environment Files (DO NOT COMMIT SECRETS)
# ==============================
.env
.env.*
!.env.example

# ==============================
# Logs
# ==============================
logs/
*.log
cypress/logs/*
!cypress/logs/.gitkeep

# Downloads — keep folder, ignore sensitive files
cypress/downloads/*
!cypress/downloads/.gitkeep

# Sensitive credentials
cypress/fixtures/credentials.xlsx

# ==============================
# Build / Output
# ==============================
dist/
build/

# ==============================
# IDE / Editor
# ==============================
.vscode/
.idea/
*.swp
*.swo

# ==============================
# OS Files
# ==============================
.DS_Store
Thumbs.db

# ==============================
# Cache / Temp
# ==============================
.cache/
.tmp/
.temp/